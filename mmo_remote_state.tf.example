#     NATS_URL        = try(local.nats.urls, "")
#     TEMPO_OTLP_GRPC = try(local.mmo.monitoring.tempo.otlp_grpc, "")
#   }
#   type = "Opaque"
# }

# Или Helm:
#
# resource "helm_release" "world_server" {
#   name       = "world-server"
