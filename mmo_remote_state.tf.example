#   set {
#     name  = "env.NATS_HOST"
#     value = local.nats.host
#   }
#   set {
#     name  = "env.NATS_PORT"
#     value = tostring(local.nats.port)
#   }
#   set_sensitive {
#     name  = "env.NATS_PASSWORD"
#     value = local.nats.password
#   }
# }

описание внешнего output 

output "mmo" {
  description = "MMO-стек: pgsql (БД mmo), Scylla, Redis, NATS, Loki/Tempo — для remote state игрового бэкенда. Пример: examples/mmo_remote_state.tf.example"
  value = {
    pgsql = local.mmo_db_config
    scylla = var.scylla_enabled ? {
      host                = module.scylla[0].cql_client_host
      port_cql            = module.scylla[0].cql_port
      username            = null
      password            = null
      authentication_note = module.scylla[0].authentication_note
    } : null
    redis = var.redis_enabled ? {
      host     = module.redis[0].host_master
      port     = module.redis[0].port
      password = var.redis_password != "" ? var.redis_password : random_password.redis_password[0].result
    } : null
    nats = var.nats_enabled ? {
      host             = module.nats[0].client_host
      port             = module.nats[0].client_port
      username         = module.nats[0].auth_username
      password         = module.nats[0].auth_password
      urls             = module.nats[0].nats_urls
      monitor_http_url = module.nats[0].monitor_http_url
    } : null
    monitoring = {
      loki = var.loki_enabled ? {
        push_url     = module.loki[0].remote_write_url
        internal_url = module.loki[0].loki_service_url
        ingress_url  = module.loki[0].loki_url
        namespace    = module.loki[0].namespace
      } : null
      tempo = var.tempo_enabled ? {
        http_url      = module.tempo[0].tempo_http_url
        http_internal = module.tempo[0].tempo_http_url_internal
        otlp_grpc     = module.tempo[0].tempo_otlp_grpc_endpoint
        otlp_http     = module.tempo[0].tempo_otlp_http_endpoint
        namespace     = module.tempo[0].namespace
      } : null
    }
  }
  sensitive = true
}