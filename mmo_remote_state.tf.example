# Пример: игровой MMO-бэкенд (отдельный стек) читает outputs.staging.mmo.
# Перед apply staging с Harbor: ./scripts/download-staging-charts.sh && ./scripts/upload-charts-to-harbor.sh nats
# Чарт: https://artifacthub.io/packages/helm/nats/nats (репозиторий nats-io)

data "terraform_remote_state" "staging" {
  backend = "kubernetes"

  config = {
    secret_suffix = "terraform" # как в iac/envs/staging/backend.tf
    namespace     = "state"
    config_path   = pathexpand("~/.kube/config")
  }
}

locals {
  mmo = data.terraform_remote_state.staging.outputs.mmo

  # Чувствительные поля — только set_sensitive / Vault / ExternalSecrets, не логировать.
  pg_mmo = try(local.mmo.pgsql, null)
  redis  = try(local.mmo.redis, null)
  nats   = try(local.mmo.nats, null)
}

# Пример: проброс в Deployment / Helm (пароли — set_sensitive)
#
# resource "kubernetes_secret" "mmo_backend" {
