# Скопируйте в grid_manager.auto.tfvars (или объедините с вашим *.auto.tfvars) и примените tofu apply.
# Осторожно: при нарушении load policy grid-manager выставит split_drain на соте (новые Join отклоняются).

# grid_manager_extra_env = {
#   MMO_GRID_AUTO_SPLIT_DRAIN = "true"
#   MMO_GRID_AUTO_SPLIT_WORKFLOW = "true"
#   # по умолчанию true: после retire_ready — preflight и phase=automation_complete в Redis
#   # MMO_GRID_AUTO_POST_HANDOFF_ORCHESTRATION = "false"
#   # registry gRPC для self-call в workflow: в кластере — DNS сервиса grid-manager
#   MMO_GRID_REGISTRY_ADDR = "mmo-grid-manager.mmo.svc.cluster.local:9100"
#   # локально / только port-forward на grid-manager: "127.0.0.1:9100"
#   # опционально укоротить окна для отладки:
#   # MMO_GRID_LOAD_POLICY_MIN_BREACH_DURATION = "8s"
#   # MMO_GRID_LOAD_POLICY_COOLDOWN             = "60s"
#   # MMO_GRID_CELL_PROBE_INTERVAL            = "6s"
#   # MMO_GRID_SPLIT_WORKFLOW_MAX_RETRIES     = "4"
#   # MMO_GRID_SPLIT_WORKFLOW_BACKOFF         = "1s"
#   # MMO_GRID_SPLIT_WORKFLOW_MAX_BACKOFF     = "12s"
#   # guardrails (по умолчанию выключены):
#   # MMO_GRID_SPLIT_MAX_LEVEL                = "3"              # не запускать split workflow для cell level >= 3
#   # MMO_GRID_SPLIT_MAX_CONCURRENT_WORKFLOWS = "2"              # ограничить параллельные workflow
#   # MMO_GRID_SPLIT_WORKFLOW_BLOCKLIST       = "cell_0_0_0"     # CSV cell_id, для которых workflow запрещён
#
#   # Auto merge (scale-in), см. docs/cells-migration-workflow.md
#   MMO_GRID_AUTO_MERGE_WORKFLOW              = "true"
#   MMO_GRID_MERGE_MIN_LOW_LOAD_DURATION      = "3m"
#   MMO_GRID_MERGE_COOLDOWN                   = "6m"
#   MMO_GRID_MERGE_THRESHOLD_MAX_PLAYERS      = "0"
#   MMO_GRID_MERGE_THRESHOLD_MAX_ENTITIES     = "300"
#   MMO_GRID_MERGE_THRESHOLD_MAX_TICK_SECONDS = "0.01"
# }
