#     level = 0
#     xmin  = -1000
#     xmax  = 1000
#     zmin  = -1000
#     zmax  = 1000
#   }
#   "child-sw" = {
#     id    = "cell_q0"
#     level = 1
#     xmin  = -1000
#     xmax  = 0
#     zmin  = -1000
#     zmax  = 0
#   }
# }
